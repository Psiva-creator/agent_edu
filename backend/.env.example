# ═══════════════════════════════════════════════════════════════
# Career Guide AI — Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy to .env:  cp .env.example .env
# ═══════════════════════════════════════════════════════════════

# ─── Application ──────────────────────────────────────────────
APP_NAME=Career Guide AI
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO

# ─── Server ───────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── OpenAI (optional — fallback engine works without it) ────
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=4096

# ─── Gemini (optional — used instead of OpenAI if set) ───────
# Free-tier Gemini keys hit rate limits fast. GEMINI_API_KEY_2 and
# _3 are optional backup keys — the service automatically rotates
# to the next one when the current key's quota is exhausted, and
# retries the first key again after a short cooldown once all are
# exhausted. Get free keys at https://aistudio.google.com/apikey
# (use separate Google accounts for separate keys).
GEMINI_API_KEY=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_MODEL=gemini-flash-latest

# ─── Export ───────────────────────────────────────────────────
EXPORT_DIR=exports
MAX_UPLOAD_SIZE_MB=10

# ─── SMS OTP Provider (Twilio / MSG91 / Firebase / Mock) ──────
SMS_PROVIDER=mock
SMS_ACCOUNT_ID=
SMS_AUTH_TOKEN=
SMS_SENDER_ID=
SMS_VERIFY_SERVICE_ID=

