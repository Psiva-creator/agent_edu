# ═══════════════════════════════════════════════════════════════
# Career Guide AI — Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy to .env:  cp .env.example .env
# ═══════════════════════════════════════════════════════════════

# ─── Application ──────────────────────────────────────────────
APP_NAME=Career Guide AI
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO

# ─── Server ───────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── OpenAI (optional — fallback engine works without it) ────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=4096

# ─── Export ───────────────────────────────────────────────────
EXPORT_DIR=exports
MAX_UPLOAD_SIZE_MB=10
